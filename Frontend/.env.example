# ─────────────────────────────────────────────
# Praecantator Frontend – Environment Variables
# ─────────────────────────────────────────────
# All variables MUST be prefixed with VITE_ to be
# exposed to the browser build.

# API — FastAPI backend
# VITE_API_URL  — HTTP fetch base for all API calls.
# VITE_API_BASE — Full backend URL used for WebSocket host derivation in use-websocket.ts.
#                 Keep in sync with VITE_API_URL.
#
# Local:       http://127.0.0.1:8000/api
# Production:  http://<YOUR-PRODUCTION-IP>/api   (or https://your-domain.com/api with TLS)
#              Set in the Vercel dashboard as VITE_API_URL
VITE_API_URL=http://127.0.0.1:8000/api
VITE_API_BASE=http://127.0.0.1:8000/api

# Firebase Web app (Firebase Console → Project settings → Your apps)
# For Google sign-in on Vercel: set AUTH_DOMAIN to the SPA hostname (e.g. your-app.vercel.app),
# NOT your-project.firebaseapp.com — after you add the /__/auth proxy or sync auth assets
# (see docs/DEPLOYMENT_FIREBASE.md).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional on Vercel: same value as VITE_FIREBASE_PROJECT_ID — lets /api/firebase-host read the id without a VITE_ prefix (server-only).
# FIREBASE_PROJECT_ID=

# MapLibre tile provider key (if required by your tile host)
# VITE_MAPTILER_KEY=your_maptiler_api_key_here

# Map style overrides (optional – leave blank to use defaults)
# VITE_MAP_STYLE_DARK=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
# VITE_MAP_STYLE_LIGHT=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json

# Optional fallback for the Google Maps 3D incident flyover.
# Preferred path: Backend/.env GOOGLE_MAPS_API_KEY served via /api/config/maps.
VITE_GOOGLE_MAPS_API_KEY=

# Feature flags
VITE_ENABLE_DEMO_MODE=false

# ══════════════════════════════════════════════════════════════════
# WORLDMONITOR DATA LAYER (served by Backend /api/global/*)
# ══════════════════════════════════════════════════════════════════
# NetworkView and Command Center pull live intelligence from the backend.
# No frontend API keys are required — configure sources in Backend/.env instead.
#
# Backend free-tier keys (register once, copy to Backend/.env):
#   Finnhub      → https://finnhub.io/           (FINNHUB_API_KEY)
#   EIA          → https://www.eia.gov/opendata/ (EIA_API_KEY)
#   FRED         → https://fred.stlouisfed.org/  (FRED_API_KEY)
#   NewsAPI      → https://newsapi.org/          (NEWSAPI_API_KEY)
#   GNews        → https://gnews.io/             (GNEWS_API_KEY)
#   NASA FIRMS   → https://firms.modaps.eosdis.nasa.gov/ (NASA_FIRMS_MAP_KEY)
#   ACLED        → https://acleddata.com/        (ACLED_EMAIL + ACLED_PASSWORD)
#   OpenAQ       → https://docs.openaq.org/      (OPENAQ_API_KEY)
#   AviationStack→ https://aviationstack.com/  (AVIATIONSTACK_API)
#   Groq         → https://console.groq.com/     (GROQ_API_KEY — market implications AI)
#
# No-key sources (always active via backend cron):
#   NASA EONET, USGS, GDACS, GDELT, IMF PortWatch, GIE AGSI EU gas storage
#
# Enable backend fetcher: WORLDMONITOR_FETCHER_ENABLED=true in Backend/.env
