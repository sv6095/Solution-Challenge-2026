# ─────────────────────────────────────────────────────────────────────────────
# Backend/.env.docker.example
#
# Copy this file to Backend/.env on your EC2 host and fill in all values.
# Never commit Backend/.env to git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=production

# ── Auth & Database ───────────────────────────────────────────────────────────
# AUTH_PROVIDER=firebase  → verifies Firebase ID tokens (Google Sign-In)
# AUTH_PROVIDER=local     → uses the API's own JWT (email/password flow)
AUTH_PROVIDER=firebase
DB_PROVIDER=firestore
CACHE_PROVIDER=memory
FIRESTORE_ENABLED=true
LOCAL_AUTH_BYPASS=false

# ── GCP / Firestore credentials ───────────────────────────────────────────────
# The SA key JSON is bind-mounted into the container at /secrets/gcp-sa.json
# (see docker-compose.yml). Set the three project ID vars to the same value.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
FIREBASE_PROJECT_ID=<your-gcp-project-id>
GCLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>

# ── LLM providers ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GOOGLE_API_KEY=<your-gemini-api-key>

# Groq is used as an emergency LLM fallback
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Vercel frontend URL).
CORS_ORIGINS=https://your-vercel-app.vercel.app
# Regex to allow all Vercel preview deployments automatically.
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# ── Optional signal sources ───────────────────────────────────────────────────
NEWSAPI_API_KEY=
GNEWS_API_KEY=

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_USE_LIVE=false

# ── Intelligence gap tracker ──────────────────────────────────────────────────
INTELLIGENCE_GAP_TRACKER_ENABLED=true
INTELLIGENCE_GAP_CONTEXT_QUALITY_MIN=80
INTELLIGENCE_GAP_SIGNAL_STALE_HOURS=24
INTELLIGENCE_GAP_SIGNAL_STALE_RATIO_THRESHOLD=0.35
INTELLIGENCE_GAP_SIGNAL_LOW_CORR_RATIO_THRESHOLD=0.45
INTELLIGENCE_GAP_MASTER_DATA_PENDING_THRESHOLD=10
INTELLIGENCE_GAP_REGISTRY_STALE_HOURS=720
